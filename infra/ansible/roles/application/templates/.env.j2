# Managed by Ansible

# ==============================
# Application
# ==============================

APP_ENV={{ environment | default("development") }}
APP_NAME=ad-platform
APP_VERSION=1.0.0

# ==============================
# MySQL
# ==============================

MYSQL_HOST={{ database_host | default("localhost") }}
MYSQL_PORT=3306
MYSQL_DATABASE=ad_platform
MYSQL_USER=dev
MYSQL_PASSWORD=devpass

DATABASE_URL=mysql+pymysql://dev:devpass@{{ database_host | default("localhost") }}:3306/ad_platform

# ==============================
# Tarantool
# ==============================

TARANTOOL_HOST={{ database_host | default("localhost") }}
TARANTOOL_PORT=3301

# ==============================
# ClickHouse
# ==============================

CLICKHOUSE_HOST={{ database_host | default("localhost") }}
CLICKHOUSE_PORT=8123
CLICKHOUSE_DATABASE=ad_platform

# ==============================
# RabbitMQ
# ==============================

RABBITMQ_HOST={{ database_host | default("localhost") }}
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# ==============================
# Logging
# ==============================

LOG_LEVEL={{ log_level | default("DEBUG") }}

# ==============================
# API
# ==============================

AUTH_API_PORT=8001
ADS_API_PORT=8002