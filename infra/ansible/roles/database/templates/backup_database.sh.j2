#!/bin/bash

# Managed by Ansible

BACKUP_DIR="{{ database_data_dir }}/backups"
DATE=$(date +%Y%m%d_%H%M%S)

mkdir -p $BACKUP_DIR

echo "Starting database backup..."

# MySQL backup
docker exec mysql mysqldump -u root -p{{ mysql_root_password | default("root_password") }} --all-databases > $BACKUP_DIR/mysql_$DATE.sql

# ClickHouse backup
docker exec clickhouse clickhouse-client --query="BACKUP DATABASE ad_platform TO Disk('default', 'clickhouse_backup_$DATE')"

echo "Backup completed: $DATE"